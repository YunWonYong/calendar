{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "frontend dev",
            "type": "shell",
            "command": "./scripts/dev-start.sh",
            "isBackground": true,
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": {
                "owner": "custom",
                "pattern": {
                    "regexp": ".*"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Starting Frontend",
                    "endsPattern": "compiled successfully|webpack compiled"
                }
            },
        }
    ]
}